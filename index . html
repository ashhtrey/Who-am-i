<!DOCTYPE html>
<html>
<head>
  <title>For You ❤️</title>
  <style>
    body {
      font-family: Arial;
      text-align: center;
      background-color: #ffe6f0;
      padding: 50px;
    }
    .box {
      background: white;
      padding: 25px;
      border-radius: 15px;
      display: inline-block;
      max-width: 300px;
    }
    button {
      margin: 10px;
      padding: 10px 15px;
      border: none;
      border-radius: 10px;
      background-color: pink;
      cursor: pointer;
    }
  </style>
</head>

<body>

<div class="box">
  <h2>Hey ❤️</h2>
  <p id="question">Ready for something cute?</p>
  <button onclick="start()">Start</button>

  <div id="buttons"></div>
  <p id="response"></p>
</div>

<script>

let qna = [
  {
    q: "Do you remember the first time we talked?",
    yes: "I knew you would remember 🥺❤️",
    no: "Hmm... think again. You know this 👀",
    maybe: "How can you forget that 😭"
  },
  {
    q: "Was I special to you from the beginning?",
    yes: "That makes me really happy ❤️",
    no: "Ouch... but okay, I’ll accept it 😌",
    maybe: "You’re confusing me now 😒"
  },
  {
    q: "Do you like spending time with me?",
    yes: "That’s my favorite thing too 💖",
    no: "Liar. I know you do 😏",
    maybe: "Half answer ah? Not allowed 😤"
  },
  {
    q: "Do you love me? ❤️",
    yes: "I knew it… 🥺❤️",
    no: "Still… I do 😌",
    maybe: "Say it properly 😭"
  }
];

let i = 0;

function start() {
  showQuestion();
}

function showQuestion() {
  if (i < qna.length) {
    document.getElementById("question").innerText = qna[i].q;

    document.getElementById("buttons").innerHTML = `
      <button onclick="answer('yes')">Yes</button>
      <button onclick="answer('no')">No</button>
      <button onclick="answer('maybe')">I don’t remember</button>
    `;
  } else {
    document.getElementById("question").innerText = "Okay… now come tell me everything in person 🥺❤️";
    document.getElementById("buttons").innerHTML = "";
  }
}

function answer(choice) {
  let res = qna[i][choice];
  document.getElementById("response").innerText = res;
  i++;

  setTimeout(() => {
    document.getElementById("response").innerText = "";
    showQuestion();
  }, 2000);
}

</script>

</body>
</html>
